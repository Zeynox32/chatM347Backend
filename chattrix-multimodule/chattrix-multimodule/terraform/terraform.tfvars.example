# terraform.tfvars.example
# Kopiere diese Datei zu terraform.tfvars und trage deine Werte ein.
# terraform.tfvars wird NICHT committed (siehe .gitignore).

project_id = "dein-gcp-projekt-id"
region     = "europe-west6"
zone       = "europe-west6-a"

# e2-micro = Google Free Tier (nur in us-west1 / us-central1 / us-east1 kostenlos!)
# e2-medium = empfohlen für alle 6 Services + 4 DBs (~25$/Monat, mit 300$ Startguthaben gratis nutzbar)
machine_type = "e2-medium"

ssh_user       = "deploy"
ssh_public_key = "ssh-ed25519 AAAA... deploy@chattrix"
