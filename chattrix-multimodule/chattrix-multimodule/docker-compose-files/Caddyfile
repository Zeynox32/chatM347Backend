# Caddyfile – Reverse Proxy mit automatischem Let's Encrypt SSL
#
# Setze DOMAIN als Umgebungsvariable, z.B. chattrix.example.com
# Falls du (noch) keine Domain hast, nutze stattdessen die Variante
# weiter unten (auskommentiert) mit der reinen IP-Adresse ohne SSL.

{$DOMAIN} {
	# Frontend ausliefern
	handle /api/* {
		reverse_proxy gateway-service:8080
	}

	handle /ws/* {
		reverse_proxy gateway-service:8080
	}

	handle {
		reverse_proxy frontend-service:80
	}

	encode gzip
}

# ── Alternative ohne Domain (nur IP, kein SSL) ────────────────────────────────
# Falls noch keine Domain vorhanden ist, kommentiere den Block oben aus
# und nutze stattdessen:
#
# :80 {
# 	handle /api/* {
# 		reverse_proxy gateway-service:8080
# 	}
# 	handle /ws/* {
# 		reverse_proxy gateway-service:8080
# 	}
# 	handle {
# 		reverse_proxy frontend-service:80
# 	}
# }
